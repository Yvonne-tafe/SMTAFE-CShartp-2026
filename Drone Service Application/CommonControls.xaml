<UserControl x:Class="Drone_Service_Application.CommonControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Drone_Service_Application"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" Height="17" Width="285" Grid.ColumnSpan="2"><Run FontFamily="Calibri" FontSize="16" Language="en-au" Text="Icarus Drone Service Application" Foreground="Blue" FontWeight="Bold"/></TextBlock>
        <StatusBar Margin="24,473,23,69" Grid.ColumnSpan="2">
            <TextBlock x:Name="txtStatus" Text="Status:" Width="500"/>
        </StatusBar>
        <Button x:Name="btnExit" Content="Exit" HorizontalAlignment="Left" Margin="700,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="1.56,0.633" FontSize="16" Width="50" Click="btnClose_Click"/>
    </Grid>
</UserControl>
