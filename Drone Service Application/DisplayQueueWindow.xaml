<Window x:Class="Drone_Service_Application.DisplayQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drone_Service_Application"
        mc:Ignorable="d"
        Title="Display Queues" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="7"/>
            <ColumnDefinition Width="Auto" MinWidth="789"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <local:CommonControls x:Name="CommonControls" Grid.ColumnSpan="2" Margin="0,0,33,0"/>
        <GroupBox Header="Regular Service Queue" Margin="1,50,0,137" Grid.Column="1">
            <StackPanel>
                <ListView x:Name="lvRegularService" Height="120" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client Name" Width="120"/>
                            <GridViewColumn Header="Drone Model" Width="120"/>
                            <GridViewColumn Header="Service Problem" Width="180"/>
                            <GridViewColumn Header="Service Cost" Width="90"/>
                            <GridViewColumn Header="Service Tag" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Complete Regular Service"
                Width="170"
                Height="30"
                Margin="5"
                HorizontalAlignment="Right" Click="Button_Click_CompleteRegular"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Express Service Queue" Margin="1,249,4,111" Grid.Column="1">
            <StackPanel Height="178">
                <ListView x:Name="lvExpressService" Height="120" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client Name" Width="120"/>
                            <GridViewColumn Header="Drone Model" Width="120"/>
                            <GridViewColumn Header="Service Problem" Width="180"/>
                            <GridViewColumn Header="Service Cost" Width="90"/>
                            <GridViewColumn Header="Service Tag" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Complete Express Service"
                Width="170"
                Height="30"
                Margin="5"
                HorizontalAlignment="Right" Click="Button_Click_CompleteExpress"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
