<Window x:Class="Drone_Service_Application.DisplayQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drone_Service_Application"
        mc:Ignorable="d"
        Title="Window1" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="81*"/>
            <ColumnDefinition Width="719*"/>
        </Grid.ColumnDefinitions>
        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" Height="17" Width="285" Grid.ColumnSpan="2"><Run FontFamily="Calibri" FontSize="16" Language="en-au" Text="Icarus Drone Service Application" Foreground="Blue" FontWeight="Bold"/></TextBlock>
        <GroupBox Header="Regular Service Queue" Margin="10,50
                  ,0,137" Grid.ColumnSpan="2">
            <StackPanel>
                <ListView x:Name="lvRegularService" Height="120" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client Name" Width="120"/>
                            <GridViewColumn Header="Drone Model" Width="120"/>
                            <GridViewColumn Header="Service Problem" Width="180"/>
                            <GridViewColumn Header="Service Cost" Width="90"/>
                            <GridViewColumn Header="Service Tag" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Complete Regular Service"
                Width="170"
                Height="30"
                Margin="5"
                HorizontalAlignment="Right" Click="Button_Click"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Express Service Queue" Margin="5,249,5,111" Grid.ColumnSpan="2">
            <StackPanel Height="178">
                <ListView x:Name="lvExpressService" Height="120" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client Name" Width="120"/>
                            <GridViewColumn Header="Drone Model" Width="120"/>
                            <GridViewColumn Header="Service Problem" Width="180"/>
                            <GridViewColumn Header="Service Cost" Width="90"/>
                            <GridViewColumn Header="Service Tag" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Complete Express Service"
                Width="170"
                Height="30"
                Margin="5"
                HorizontalAlignment="Right" Click="Button_Click_1"/>
            </StackPanel>
        </GroupBox>
        <StatusBar Margin="24,473,23,69" Grid.ColumnSpan="2">
            <TextBlock x:Name="txtStatus" Text="Status:" Width="500"/>
        </StatusBar>
    </Grid>
</Window>
