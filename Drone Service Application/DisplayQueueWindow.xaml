<Window x:Class="Drone_Service_Application.DisplayQueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drone_Service_Application"
        mc:Ignorable="d"
        Title="Display Queues" Height="600" Width="800">
    <Grid>
        
        <local:CommonControls x:Name="CommonControls" Grid.ColumnSpan="2" Margin="0,0,10,0"/>
        <GroupBox Header="Regular Service Queue" Margin="5,50,5,300">
            <StackPanel>
                <!--
                Feature: The service items must be displayed in a ListView which displays all the class attributes.
                -->
                    <ListView x:Name="lvRegularService" Height="120" Margin="10" SelectionChanged="Mouse_Click_InfoPage">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client Name" Width="120" DisplayMemberBinding="{Binding ClientName}"/>
                            <GridViewColumn Header="Drone Model" Width="120" DisplayMemberBinding="{Binding DroneModel}"/>
                            <GridViewColumn Header="Service Problem" Width="180" DisplayMemberBinding="{Binding ServiceProblem}"/>
                            <GridViewColumn Header="Service Cost" Width="90"  DisplayMemberBinding="{Binding ServiceCost}"/>
                            <GridViewColumn Header="Service Tag" Width="80" DisplayMemberBinding="{Binding ServiceTag}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Complete Regular Service"
                Width="170"
                Height="30"
                Margin="10"
                HorizontalAlignment="Right" Click="Button_Click_CompleteRegular"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Express Service Queue" Margin="1,270,5,100" Grid.Column="1">
            <StackPanel Height="200">
                <!--
                Feature: The service items must be displayed in a ListView which displays all the class attributes.
                -->
                <ListView x:Name="lvExpressService" Height="120" Margin="5" SelectionChanged="Mouse_Click_InfoPage">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client Name" Width="120" DisplayMemberBinding="{Binding ClientName}"/>
                            <GridViewColumn Header="Drone Model" Width="120" DisplayMemberBinding="{Binding DroneModel}"/>
                                <GridViewColumn Header="Service Problem" Width="180" DisplayMemberBinding="{Binding ServiceProblem}"/>
                            <GridViewColumn Header="Service Cost" Width="90" DisplayMemberBinding="{Binding ServiceCost}"/>
                            <GridViewColumn Header="Service Tag" Width="80" DisplayMemberBinding="{Binding ServiceTag}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Complete Express Service"
                Width="170"
                Height="30"
                Margin="5"
                HorizontalAlignment="Right" Click="Button_Click_CompleteExpress"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
