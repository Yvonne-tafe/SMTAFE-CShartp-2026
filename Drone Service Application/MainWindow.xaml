<Window x:Class="Drone_Service_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drone_Service_Application"
        mc:Ignorable="d"
        Title="Main Menu" Height="600
        " Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontSize="16" Height="17" Width="285"><Run FontFamily="Calibri" FontSize="16" Language="en-au" Text="Icarus Drone Service Application" Foreground="Blue" FontWeight="Bold"/></TextBlock>
        <Border  BorderBrush="LightGray" BorderThickness="2" CornerRadius="10" Padding="10" Margin="10,50,10,135" >
            <StackPanel>
                <Button Content="Add New Drone" Margin="0,50,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
                <Button Content="Display Queues" Margin="0,20,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click_1">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
                <Button Content="Display Final List" Margin="0,20,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click_2">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Border>
        <StatusBar Margin="24,473,23,69" Grid.ColumnSpan="2">
            <TextBlock x:Name="txtStatus" Text="Status:" Width="500"/>
        </StatusBar>
    </Grid>
</Window>
