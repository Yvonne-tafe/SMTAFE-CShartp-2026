<Window x:Class="Drone_Service_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drone_Service_Application"
        mc:Ignorable="d"
        Title="Main Menu" Height="600
        " Width="800">
    <Grid>
        <local:CommonControls x:Name="CommonControls" Grid.ColumnSpan="2" Margin="0,0,33,0"/>
        <Border  BorderBrush="LightGray" BorderThickness="2" CornerRadius="10" Padding="10" Margin="10,50,10,135" >
            <StackPanel>
                <Button Content="Add New Drone" Margin="0,20,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click_AddNewDrone">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
                <Button Content="Display Queues" Margin="0,20,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click_ShowQueues">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
                <Button Content="Display Final List" Margin="0,20,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click_ShowFinalList">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
                <Button Content="Exit" Margin="0,20,0,20" Width="300" FontSize="14" Height="50" Click="Button_Click_Exit">
                    <Button.Effect>
                        <DropShadowEffect/>
                    </Button.Effect>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
